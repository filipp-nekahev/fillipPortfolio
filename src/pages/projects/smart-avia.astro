---
import Layout from "../../layouts/Main.astro";
---

<Layout>
  <div class="max-w-[660px] mx-auto px-[var(--container-padding)]">
    <!-- Header Section -->
    <section class="pt-[4rem] pb-[3rem]">
      <div class="flex items-center gap-4 mb-6">
        <a
          href="/"
          class="text-[var(--color-description)] hover:text-[var(--color-text)] transition-colors"
        >
          ← Back to Portfolio
        </a>
      </div>

      <div class="grid items-center">
        <div>
          <h1 class="text-[3rem] font-semibold leading-tight mb-4">
            SmartAvia
          </h1>
          <p class="text-[1.25rem] text-[var(--color-description)] mb-6">
            Freelance 2019
          </p>
          <h2>Website Redesign</h2>
          <p>
            Freelance project redesigning core website elements for flight
            booking experience. Developed desktop and mobile versions covering
            flight search interface, seat selection system, passenger
            management, and payment processing workflows. Created intuitive
            booking flow with calendar selection, passenger details, and
            multiple payment options including cards and digital wallets.
          </p>

          <h2>In-Flight Entertainment</h2>
          <p>
            Designed comprehensive offline entertainment platform accessible via
            airplane Wi-Fi without global internet access. Created interfaces
            for movies, music, books, games, and onboard shopping, optimizing
            for various screen sizes and offline functionality. System allows
            passengers to consume entertainment content during flight without
            requiring global internet connection.
          </p>
        </div>
      </div>
    </section>
  </div>
</Layout>
