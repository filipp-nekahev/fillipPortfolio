---
import Layout from "@/layouts/Project.astro";
import Heading from "@/components/ui/Heading.astro";
import Text from "@/components/ui/Text.astro";

const title = "MNFST";
const years = "Freelance 2018";
---

<Layout {title} {years}>
  <Heading level={2} size="xl" weight="semibold"
    >B2B influencer marketing platform</Heading
  >
  <Text class="mb-[1.562rem]"
    >Designed B2B dashboard enabling brands to create sponsored photo campaigns
    where social media users overlay brand elements on personal content and earn
    money based on engagement. Created 30+ artboards covering complete platform
    for campaign management, targeting, budget allocation, and performance
    tracking across Facebook, Instagram, Twitter, and VKontakte.</Text
  >
</Layout>
