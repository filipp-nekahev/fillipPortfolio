<section
  id="hero"
  class="text-center h-screen flex flex-col justify-center gap-4 px-[var(--container-padding)]"
>
  <h1 class="text-[2.375rem] font-semibold leading-none">Filipp Nekhaev</h1>
  <div class="flex flex-col text-[1.125rem] text-[var(--color-description)]">
    <p class="">Senior Product Designer</p>
    <p class="opacity-60">UI/UX Designer</p>
  </div>
  <canvas
    id="hero-wave"
    class="w-full max-w-[600px] h-[120px] mx-auto"
    aria-hidden="true"
  >
  </canvas>
</section>

<script>
  const canvas = document.getElementById("hero-wave") as HTMLCanvasElement | null;

  if (canvas) {
    const ctx = canvas.getContext("2d");
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    );

    const ROWS = 3;
    const COLS = 60;
    const DOT_RADIUS = 1.5;
    const COLOR = "rgba(160, 160, 160, 0.16)";

    let width = 0;
    let height = 0;
    let dpr = 1;
    let rafId = 0;
    let time = 0;

    const resize = () => {
      dpr = window.devicePixelRatio || 1;
      width = canvas.clientWidth;
      height = canvas.clientHeight;
      canvas.width = Math.round(width * dpr);
      canvas.height = Math.round(height * dpr);
      if (ctx) ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const draw = () => {
      if (!ctx) return;
      ctx.clearRect(0, 0, width, height);
      ctx.fillStyle = COLOR;

      const rowGap = height / (ROWS + 1);
      const colGap = width / (COLS - 1);

      for (let r = 0; r < ROWS; r++) {
        const baseY = rowGap * (r + 1);
        for (let c = 0; c < COLS; c++) {
          const x = colGap * c;
          const phase = c * 0.35 + r * 0.6 + time;
          const y = baseY + Math.sin(phase) * (rowGap * 0.35);
          ctx.beginPath();
          ctx.arc(x, y, DOT_RADIUS, 0, Math.PI * 2);
          ctx.fill();
        }
      }
    };

    const animate = () => {
      time += 0.03;
      draw();
      rafId = requestAnimationFrame(animate);
    };

    const start = () => {
      cancelAnimationFrame(rafId);
      if (prefersReducedMotion.matches) {
        draw();
      } else {
        animate();
      }
    };

    const handleResize = () => {
      resize();
      start();
    };

    resize();
    start();

    window.addEventListener("resize", handleResize);
    prefersReducedMotion.addEventListener("change", start);
  }
</script>
