---
import linkArrowRaw from "@/assets/link_arrow.svg?raw";

export interface Props {
  href: string;
  title: string;
  years: string;
  image: string;
  mobileImage?: string;
  class?: string | string[];
}
const {
  href,
  title,
  years,
  image,
  mobileImage,
  class: extra = "",
} = Astro.props;

const mobImg = mobileImage || image;
---

<a
  href={href}
  class:list={[
    "group relative flex flex-col h-[440px] w-full overflow-hidden rounded-2xl transition-all ease-in-out duration-[250ms] lg:hover:scale-[1.03]",
    extra,
  ]}
>
  <picture class="absolute inset-0 w-full h-full z-0">
    <source media="(min-width: 640px)" srcset={image} />
    <img
      src={mobImg}
      alt={title}
      class="w-full h-full object-cover"
      loading="lazy"
      decoding="async"
    />
  </picture>
  <div class="mt-auto p-4 flex items-end justify-between relative">
    <div>
      <h3 class="text-white text-lg font-semibold">{title}</h3>
      <p class="text-white/80 text-sm">{years}</p>
    </div>
    <span class="h-4 w-4 text-indigo-500" set:html={linkArrowRaw} />
  </div>
</a>
