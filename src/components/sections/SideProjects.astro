---
import PortfolioCard from "@components/cards/PortfolioCard.astro";
//Images
import fillWiseImg from "@/assets/fillWise.jpg";
import aiHairStylerImg from "@/assets/aihairstyle.jpg";
import reWriteImg from "@/assets/re_writing.jpg";

const sideProjects = [
  {
    href: "/projects/fill-wise",
    title: "FillWise",
    years: "Side Project 2025",
    image: fillWiseImg,
  },
  {
    href: "/projects/all-hair",
    title: "AI Hair Styler", // Fix title
    years: "2024",
    image: aiHairStylerImg,
  },
  {
    href: "/projects/re-writing",
    title: "ReWriter", // Fix title
    years: "2023",
    image: reWriteImg,
  },
];
---

<section aria-labelledby="side-projects-heading">
  <h3 id="side-projects-heading" class="text-text text-[1.125rem] mb-[1.5rem] px-[var(--container-padding)]">
    Side projects
  </h3>
  <div
    class="grid grid-flow-col auto-cols-[90%] sm:auto-cols-auto sm:grid-flow-row gap-[1.5rem]
    overflow-x-auto sm:overflow-visible scroll-smooth snap-x snap-mandatory no-scrollbar
    px-[var(--container-padding)] sm:px-[var(--container-padding)]
    sm:grid-cols-2 lg:grid-cols-3
    scroll-px-[var(--container-padding)]"
    aria-label="Side projects gallery"
  >
    {
      sideProjects.map((item, i) => (
        <PortfolioCard {...item} class="snap-center" />
      ))
    }
  </div>
</section>
